# Copy this file to .env and fill in real values. .env is gitignored and must
# never be committed. See DEVELOPMENT.md for how to obtain each of these.

# --- The only two values a fresh production install needs filled in by hand
# (docker-compose.yml, ROADMAP.md §8 -- see docs/self-hosting.md) ---

# Password for the Postgres user the stack creates for itself. Pick a real
# random value for a real deployment; docker-compose.yml refuses to start
# without one set.
POSTGRES_PASSWORD=

# The public domain name pointed at this box, e.g. forum.example.com. Caddy
# uses this both to reverse-proxy to the web container and to request its
# Let's Encrypt certificate automatically -- DNS must already point here
# before first `docker compose up` or the ACME challenge will fail.
THREADBARE_DOMAIN=

# Everything below is either collected automatically by the first-run setup
# wizard once the stack is up (the Discord bot token/OAuth values and the
# Flask secret key -- see docs/self-hosting.md), or only used for local
# development and the live-Discord test suite (see DEVELOPMENT.md). Don't
# fill any of it in by hand for a production install.

# Bot token from the Discord Developer Portal (Bot tab). Grants the sync
# worker gateway + REST access. Never a user token.
DISCORD_BOT_TOKEN=

# OAuth2 client credentials from the same Discord application, used for the
# member login gate (identify + guilds scopes).
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# The exact redirect URI registered under OAuth2 -> General -> Redirects in
# the developer portal. Must match byte-for-byte (scheme, host, port, path)
# or Discord rejects the callback with an opaque error. For local dev:
# http://localhost:5000/oauth/callback (see DEVELOPMENT.md).
DISCORD_OAUTH_REDIRECT_URI=

# The guild ID of your dev/test Discord server (see DEVELOPMENT.md).
DISCORD_TEST_GUILD_ID=

# Webhook URL for a test channel on your dev/test Discord server, used only by
# the live full-lifecycle test (tests/live_discord/test_full_lifecycle.py) to
# post/edit/delete messages as a test actor distinct from the sync worker's
# bot. See DEVELOPMENT.md for how to create one and why a webhook rather than
# a second bot.
DISCORD_TEST_WEBHOOK_URL=

# A persistent thread on the test server's #general, used by the thread
# backfill live tests (tests/live_discord/test_thread_backfill.py). Created
# once manually — Discord webhooks can only auto-create threads in forum
# channels, so a plain text-channel thread can't be spun up on the fly.
# See DEVELOPMENT.md for how to create one.
DISCORD_TEST_THREAD_ID=

# A persistent forum channel on the test server, used by the forum-channel
# branch's live test (tests/live_discord/test_forum_channel.py). Created once
# manually (Server Settings → Channels → Create Channel → Forum) — unlike
# plain-text threads, a webhook *can* auto-create a forum post on the fly via
# thread_name=, so only the parent forum channel itself needs to be
# persistent. See DEVELOPMENT.md.
DISCORD_TEST_FORUM_CHANNEL_ID=

# Webhook bound to the forum channel above (webhooks can't post cross-channel,
# so this is separate from DISCORD_TEST_WEBHOOK_URL). Used to auto-create a
# forum post via thread_name= for the forum-channel branch's live test.
DISCORD_TEST_FORUM_WEBHOOK_URL=

# Postgres connection string. Matches the credentials in docker-compose.dev.yml.
DATABASE_URL=postgresql://threadbare:threadbare@localhost:5432/threadbare_dev

# Same Postgres instance, separate database — used only by the integration test
# suite (tests/integration/), so tests never touch dev data.
TEST_DATABASE_URL=postgresql://threadbare:threadbare@localhost:5432/threadbare_test

# Flask session signing key. Any random string locally; a real secret in prod.
FLASK_SECRET_KEY=dev-secret-change-me
