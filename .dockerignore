tests/
docker/
docker-compose.dev.yml
# deploy/cdk's own build/dependency output -- irrelevant to the app image,
# and cdk.out nested under the repo root it's built from will otherwise
# recursively copy itself into itself when CDK stages this directory as a
# Docker build context (confirmed: an ENAMETOOLONG crash during `cdk synth`
# without this exclusion).
deploy/cdk/node_modules
deploy/cdk/cdk.out
DEVELOPMENT.md
DESIGN.md
ROADMAP.md
CLAUDE.md

# Never bake secrets into an image layer -- .env is always a runtime
# bind-mount/env_file, never COPY'd. Nothing currently does a bare
# `COPY . .` that would pick this up, but this is belt-and-suspenders.
.env
